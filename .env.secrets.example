# GitHub Configuration
GITHUB_TOKEN=your-github-personal-access-token-here

# ArgoCD Non-Prod Configuration
ARGOCD_TOKEN=your-argocd-jwt-token-here
ARGOCD_NONPROD_SERVER_URL=https://your-argocd-nonprod-server.example.com
ARGOCD_NONPROD_TOKEN=your-argocd-nonprod-jwt-token-here
ARGOCD_NONPROD_NAMESPACE=argocd

# ArgoCD Prod Configuration
ARGOCD_PROD_SERVER_URL=https://your-argocd-prod-server.example.com
ARGOCD_PROD_TOKEN=your-argocd-prod-jwt-token-here
ARGOCD_PROD_NAMESPACE=argocd

# Azure DevOps Configuration (legacy, optional)
# AZURE_DEVOPS_PAT=your-azure-devops-personal-access-token-here

# AI Configuration (choose one provider)
# Option 1: Ollama (local)
# AI_PROVIDER=ollama
# AI_OLLAMA_URL=http://localhost:11434
# AI_OLLAMA_MODEL=llama3.2
# AI_AGENT_MODEL=llama3.1:8b

# Option 2: Claude (Anthropic)
# AI_PROVIDER=claude
# AI_API_KEY=sk-ant-...
# AI_CLOUD_MODEL=claude-sonnet-4-20250514

# Option 3: OpenAI
# AI_PROVIDER=openai
# AI_API_KEY=sk-...
# AI_CLOUD_MODEL=gpt-4o

# Option 4: Google Gemini (free tier available)
# AI_PROVIDER=gemini
# AI_API_KEY=AIzaSy...
# AI_CLOUD_MODEL=gemini-2.5-flash

# Datadog Metrics (optional - enables real-time K8s resource metrics)
# DATADOG_API_KEY=your-datadog-api-key
# DATADOG_APP_KEY=your-datadog-app-key
# DATADOG_SITE=datadoghq.com
