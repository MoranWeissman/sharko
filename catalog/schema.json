{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sharko.dev/schemas/catalog/addons.json",
  "title": "Sharko Catalog",
  "description": "Curated addon catalog embedded into the Sharko binary. Validated at load time by internal/catalog/loader.go; this JSON Schema is the human-readable contract and is also consumed by the catalog-validate CI workflow (v1.21 Epic 8).",
  "type": "object",
  "required": ["addons"],
  "additionalProperties": false,
  "properties": {
    "addons": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/CatalogEntry" }
    }
  },
  "$defs": {
    "CatalogEntry": {
      "type": "object",
      "required": [
        "name",
        "description",
        "chart",
        "repo",
        "default_namespace",
        "category",
        "curated_by",
        "license",
        "maintainers"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "maxLength": 63,
          "description": "Unique, DNS-compatible addon identifier."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "chart": {
          "type": "string",
          "minLength": 1,
          "description": "Helm chart name in the upstream repo."
        },
        "repo": {
          "type": "string",
          "format": "uri",
          "pattern": "^(https?|oci)://",
          "description": "Upstream Helm repository URL. Classic http(s) repos must be reachable via GET <repo>/index.yaml; oci:// is supported for Helm 3.8+ OCI registries (e.g. AWS public ECR for Karpenter)."
        },
        "default_namespace": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "maxLength": 63
        },
        "default_sync_wave": {
          "type": "integer",
          "minimum": -100,
          "maximum": 100
        },
        "docs_url": { "type": "string", "format": "uri" },
        "homepage": { "type": "string", "format": "uri" },
        "source_url": { "type": "string", "format": "uri" },
        "maintainers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "license": {
          "type": "string",
          "minLength": 1,
          "description": "SPDX license identifier. CI flags non-allow-list values for human review (allow-list: Apache-2.0, BSD-3-Clause, MIT, MPL-2.0)."
        },
        "category": {
          "type": "string",
          "enum": [
            "security",
            "observability",
            "networking",
            "autoscaling",
            "gitops",
            "storage",
            "database",
            "backup",
            "chaos",
            "developer-tools"
          ]
        },
        "curated_by": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "cncf-graduated",
              "cncf-incubating",
              "cncf-sandbox",
              "aws-eks-blueprints",
              "azure-aks-addon",
              "gke-marketplace",
              "artifacthub-verified",
              "artifacthub-official"
            ]
          }
        },
        "security_score": {
          "oneOf": [
            { "type": "number", "minimum": 0, "maximum": 10 },
            { "type": "string", "enum": ["unknown"] }
          ],
          "description": "OpenSSF Scorecard aggregate 0-10. 'unknown' allowed when not yet queried; refreshed in-memory daily."
        },
        "security_score_updated": {
          "type": "string",
          "description": "ISO-8601 date (YYYY-MM-DD) of last Scorecard refresh."
        },
        "github_stars": {
          "type": "integer",
          "minimum": 0
        },
        "min_kubernetes_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
        },
        "deprecated": { "type": "boolean" },
        "superseded_by": { "type": "string" }
      }
    }
  }
}
