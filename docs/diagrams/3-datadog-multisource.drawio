<mxfile host="app.diagrams.net">
  <diagram name="Datadog Multi-Source Flow" id="datadog-multisource">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Datadog Deployment: Current (3 Apps) vs Proposed (Multi-Source)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="1200" height="40" as="geometry" />
        </mxCell>

        <!-- CURRENT (LEFT SIDE) -->
        <mxCell id="current-title" value="CURRENT: 3 Separate Applications" style="text;html=1;strokeColor=none;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=18;fontStyle=1;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- ApplicationSet generates -->
        <mxCell id="current-appset" value="ApplicationSet Template" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- App 1: Datadog -->
        <mxCell id="current-app1" value="Application 1:&#xa;datadog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="250" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="current-app1-source" value="Source:&#xa;helm.datadoghq.com/datadog" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="80" y="320" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow from AppSet to App1 -->
        <mxCell id="arrow-app1" value="" style="endArrow=classic;html=1;exitX=0.25;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="current-appset" target="current-app1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="400" y="400" as="sourcePoint" />
            <mxPoint x="450" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- App 2: datadog-apikey-secret -->
        <mxCell id="current-app2" value="Application 2:&#xa;datadog-apikey-secret" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="290" y="250" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="current-app2-source" value="Source:&#xa;charts/datadog-apikey-secret" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="290" y="320" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow from AppSet to App2 -->
        <mxCell id="arrow-app2" value="" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="current-appset" target="current-app2">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="400" y="400" as="sourcePoint" />
            <mxPoint x="450" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- App 3: datadog-tags -->
        <mxCell id="current-app3" value="Application 3:&#xa;datadog-tags" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="500" y="250" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="current-app3-source" value="Source:&#xa;charts/datadog-tags" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="500" y="320" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow from AppSet to App3 -->
        <mxCell id="arrow-app3" value="" style="endArrow=classic;html=1;exitX=0.75;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="current-appset" target="current-app3">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="400" y="400" as="sourcePoint" />
            <mxPoint x="450" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Issues box -->
        <mxCell id="current-issues" value="ISSUES:" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="600" height="120" as="geometry" />
        </mxCell>

        <mxCell id="current-issues-text" value="❌ 3 separate Applications to manage&#xa;❌ Coordination required (secrets must exist before Datadog deploys)&#xa;❌ Separate charts to maintain (datadog-apikey-secret, datadog-tags)&#xa;❌ Sync order dependencies not guaranteed&#xa;❌ More complexity in ApplicationSet template" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="90" y="430" width="580" height="80" as="geometry" />
        </mxCell>

        <!-- Arrow separator -->
        <mxCell id="separator-arrow" value="" style="shape=flexArrow;endArrow=classic;html=1;fillColor=#d5e8d4;strokeColor=#82b366;width=40;endSize=10;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="720" y="300" as="sourcePoint" />
            <mxPoint x="850" y="300" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="separator-label" value="CONSOLIDATE" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="720" y="260" width="130" height="30" as="geometry" />
        </mxCell>

        <!-- PROPOSED (RIGHT SIDE) -->
        <mxCell id="proposed-title" value="PROPOSED: Single Multi-Source Application" style="text;html=1;strokeColor=none;fillColor=#d5e8d4;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=18;fontStyle=1;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="880" y="80" width="640" height="40" as="geometry" />
        </mxCell>

        <!-- ApplicationSet -->
        <mxCell id="proposed-appset" value="ApplicationSet Template&#xa;(with multi-source logic)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1080" y="150" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- Single Application -->
        <mxCell id="proposed-app" value="Single Application: datadog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1020" y="250" width="360" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow from AppSet to App -->
        <mxCell id="arrow-proposed" value="" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=2;" edge="1" parent="1" source="proposed-appset" target="proposed-app">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="900" y="400" as="sourcePoint" />
            <mxPoint x="950" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Source 1 -->
        <mxCell id="proposed-source1" value="Source 1: Datadog Helm Chart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="900" y="350" width="240" height="40" as="geometry" />
        </mxCell>

        <mxCell id="proposed-source1-detail" value="repoURL: helm.datadoghq.com&#xa;chart: datadog&#xa;targetRevision: &lt;version&gt;&#xa;valueFiles:&#xa;  - $values/config/values/{{.name}}.yaml" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=5;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="900" y="400" width="240" height="90" as="geometry" />
        </mxCell>

        <!-- Arrow from App to Source 1 -->
        <mxCell id="arrow-source1" value="" style="endArrow=classic;html=1;exitX=0.25;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="proposed-app" target="proposed-source1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="900" y="400" as="sourcePoint" />
            <mxPoint x="950" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Source 2 -->
        <mxCell id="proposed-source2" value="Source 2: Configuration Chart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1180" y="350" width="240" height="40" as="geometry" />
        </mxCell>

        <mxCell id="proposed-source2-detail" value="repoURL: &lt;this-repo&gt;&#xa;path: charts/datadog-configuration&#xa;targetRevision: dev&#xa;&#xa;Includes:&#xa;  - ESO ExternalSecret (API key)&#xa;  - ESO ExternalSecret (tags)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=5;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="1180" y="400" width="240" height="110" as="geometry" />
        </mxCell>

        <!-- Arrow from App to Source 2 -->
        <mxCell id="arrow-source2" value="" style="endArrow=classic;html=1;exitX=0.75;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="proposed-app" target="proposed-source2">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="900" y="400" as="sourcePoint" />
            <mxPoint x="950" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Deployment flow -->
        <mxCell id="deploy-title" value="Deployment Flow:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="900" y="530" width="520" height="30" as="geometry" />
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="deploy-step1" value="1. ArgoCD syncs both sources simultaneously" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="900" y="565" width="520" height="35" as="geometry" />
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="deploy-step2" value="2. ESO fetches secrets from AWS Secrets Manager and creates K8s secrets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="900" y="610" width="520" height="35" as="geometry" />
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="deploy-step3" value="3. Datadog Helm chart deploys with secrets available (apiKeyExistingSecret: {{.name}})" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="900" y="655" width="520" height="35" as="geometry" />
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="deploy-step4" value="4. Single Application manages everything - Datadog + API key secret + tags secret" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="900" y="700" width="520" height="35" as="geometry" />
        </mxCell>

        <!-- Benefits box -->
        <mxCell id="proposed-benefits" value="BENEFITS:" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="880" y="760" width="640" height="150" as="geometry" />
        </mxCell>

        <mxCell id="proposed-benefits-text" value="✅ Single Application to manage (3 apps → 1 app)&#xa;✅ Integrated deployment (secrets + Datadog together)&#xa;✅ No coordination needed between separate apps&#xa;✅ Cleaner ApplicationSet template&#xa;✅ Leverages ArgoCD multi-source feature (official pattern)&#xa;✅ ESO-based secrets (no AVP)&#xa;✅ Automatic sync ordering (ArgoCD handles dependencies)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="890" y="790" width="620" height="110" as="geometry" />
        </mxCell>

        <!-- Code snippet box -->
        <mxCell id="code-snippet" value="Template Snippet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="550" width="600" height="210" as="geometry" />
        </mxCell>

        <mxCell id="code-text" value="{{- if eq $appset.appName &quot;datadog&quot; }}&#xa;sources:&#xa;  # Main Datadog chart&#xa;  - repoURL: {{ $appset.repoURL }}&#xa;    chart: {{ $appset.chart }}&#xa;    targetRevision: {{ $env.version }}&#xa;    helm:&#xa;      valueFiles:&#xa;        - $values/config/values/{{ .name }}.yaml&#xa;  # Configuration chart (ESO secrets)&#xa;  - repoURL: {{ $.Values.repoURL }}&#xa;    path: charts/datadog-configuration&#xa;{{- else }}&#xa;  # Regular single-source for other addons&#xa;{{- end }}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Courier New;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="90" y="580" width="580" height="170" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
