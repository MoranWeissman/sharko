# Copy this file to secrets.env and fill in your values.
# secrets.env is gitignored — never commit real secrets.

# Encryption key for migration credentials (AES-256-GCM)
# Generate with: openssl rand -base64 32
AAP_ENCRYPTION_KEY=

# GitHub token (required for Git operations)
GITHUB_TOKEN=ghp_your_token_here

# AI Provider — set AI_PROVIDER to one of: ollama, openai, claude, gemini, custom-openai
AI_PROVIDER=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Custom OpenAI-compatible (e.g., enterprise LLM gateway)
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_MODEL=gpt-4-1-2025-04-14
CUSTOM_OPENAI_BASE_URL=
CUSTOM_OPENAI_AUTH_HEADER=

# GitOps write operations (PR creation)
# GITOPS_ACTIONS_ENABLED=true

# Agent tool-calling loop limit (default: 8, increase for migration workflows)
# AI_MAX_ITERATIONS=25

# ArgoCD token (if not using in-cluster service account)
# ARGOCD_TOKEN=your-argocd-token

# Datadog (optional)
# DATADOG_API_KEY=your-dd-api-key
# DATADOG_APP_KEY=your-dd-app-key
