        <!-- Current: Bootstrap -->
        <mxCell id="current-bootstrap" value="Bootstrap&#xa;app-of-apps/cluster-addons/&#xa;(Nested structure)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="150" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Current: ArgoCD Config -->
        <mxCell id="current-argocd" value="ArgoCD Config&#xa;(Managed internally)&#xa;❌ Coupling issue" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="260" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Current: Datadog Apps -->
        <mxCell id="current-datadog" value="Datadog Deployment&#xa;3 Separate Applications:&#xa;• datadog&#xa;• datadog-apikey-secret&#xa;• datadog-tags" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="150" width="280" height="100" as="geometry" />
        </mxCell>

        <!-- Current: Security -->
        <mxCell id="current-security" value="Secret Management&#xa;Mixed Model:&#xa;• ESO for cluster credentials&#xa;• AVP for Datadog tags&#xa;❌ Plaintext in Redis cache" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="280" width="280" height="120" as="geometry" />
        </mxCell>

        <!-- Current: Config -->
        <mxCell id="current-config" value="Configuration&#xa;values/addons-config/&#xa;• Nested override folders&#xa;• Empty files required&#xa;• Complex structure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="370" width="240" height="120" as="geometry" />
        </mxCell>

        <!-- Current: AppSet -->
        <mxCell id="current-appset" value="ApplicationSet Template&#xa;150+ lines&#xa;❌ Hardcoded if/else chains&#xa;❌ Addon-specific logic&#xa;❌ Requires template changes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="520" width="240" height="120" as="geometry" />
        </mxCell>

        <!-- Arrow separator -->
        <mxCell id="arrow-separator" value="" style="shape=flexArrow;endArrow=classic;html=1;fillColor=#d5e8d4;strokeColor=#82b366;width=30;endSize=8;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="750" y="400" as="sourcePoint" />
            <mxPoint x="850" y="400" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="arrow-label" value="MODERNIZATION" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="740" y="360" width="120" height="30" as="geometry" />
        </mxCell>

        <!-- PROPOSED ARCHITECTURE (RIGHT SIDE) -->
        <mxCell id="proposed-title" value="PROPOSED ARCHITECTURE" style="text;html=1;strokeColor=none;fillColor=#d5e8d4;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=18;fontStyle=1;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="900" y="80" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- Proposed: Bootstrap -->
        <mxCell id="proposed-bootstrap" value="Bootstrap&#xa;bootstrap/&#xa;✅ Simple structure (no nested subfolders)&#xa;✅ Templates directly in templates/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="920" y="150" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Proposed: ArgoCD External -->
        <mxCell id="proposed-argocd" value="ArgoCD Config&#xa;✅ Managed by ArgoFleet&#xa;✅ Separation of concerns" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="920" y="260" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Proposed: Datadog Multi-Source -->
        <mxCell id="proposed-datadog" value="Datadog Deployment&#xa;1 Application (Multi-Source):&#xa;• Source 1: Datadog Helm chart&#xa;• Source 2: Configuration chart (ESO)&#xa;✅ Integrated deployment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1200" y="150" width="280" height="120" as="geometry" />
        </mxCell>

        <!-- Proposed: Security -->
        <mxCell id="proposed-security" value="Secret Management&#xa;ESO Exclusively:&#xa;• All secrets via ESO&#xa;• No AVP dependency&#xa;✅ No plaintext caching&#xa;✅ K8s secrets only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1200" y="300" width="280" height="120" as="geometry" />
        </mxCell>

        <!-- Proposed: Config -->
        <mxCell id="proposed-config" value="Configuration&#xa;configuration/&#xa;✅ 4 root files (catalog, clusters, bootstrap, global)&#xa;✅ One file per cluster in clusters/&#xa;✅ Flat structure&#xa;✅ ignoreMissingValueFiles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="920" y="370" width="240" height="120" as="geometry" />
        </mxCell>

        <!-- Proposed: AppSet -->
        <mxCell id="proposed-appset" value="ApplicationSet Template&#xa;~50 lines&#xa;✅ Data-driven approach&#xa;✅ Generic template&#xa;✅ No template changes needed&#xa;✅ Metadata in addons-catalog.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="920" y="520" width="260" height="120" as="geometry" />
        </mxCell>

        <!-- Key Benefits Box -->
        <mxCell id="benefits-box" value="KEY BENEFITS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=16;fontStyle=1;align=center;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="920" y="680" width="560" height="140" as="geometry" />
        </mxCell>

        <mxCell id="benefits-text" value="• Simpler architecture (66% reduction in template complexity)&#xa;• Better security (ESO-only, no plaintext caching)&#xa;• Improved maintainability (data-driven, no hardcoded logic)&#xa;• Separation of concerns (ArgoFleet owns ArgoCD)&#xa;• Easier to add new addons (update data only)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=14;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="930" y="710" width="540" height="100" as="geometry" />
        </mxCell>

        <!-- Challenges Box -->
        <mxCell id="challenges-box" value="CHALLENGES ADDRESSED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16;fontStyle=1;align=center;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="100" y="680" width="580" height="140" as="geometry" />
        </mxCell>

        <mxCell id="challenges-text" value="❌ Security: AVP stores secrets in plaintext Redis cache&#xa;❌ Complexity: Nested folder structure, 3 separate Datadog apps&#xa;❌ Duplication: Hardcoded logic in ApplicationSet template&#xa;❌ Configuration sprawl: Override folders with many small files&#xa;❌ Coupling: Solution manages ArgoCD config" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=14;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="110" y="710" width="560" height="100" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
