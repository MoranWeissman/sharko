        <!-- Secret -> ApplicationSets -->
        <mxCell id="e5" value="Generates&#xa;Targets" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="secret" target="remote-cluster">
           <!-- This is conceptual; usually secret creates connection, AppSet uses it.
