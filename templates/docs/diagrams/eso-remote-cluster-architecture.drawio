<mxfile host="app.diagrams.net">
  <diagram name="ESO Remote Cluster Architecture" id="eso-remote">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="900">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- AWS Secrets Manager (External) -->
        <mxCell id="aws-sm" value="AWS Secrets Manager&#xa;&#xa;datadog-api-keys-integration" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#FF9900;strokeColor=#d79b00;fontColor=#ffffff;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="300" width="200" height="120" as="geometry"/>
        </mxCell>

        <!-- Remote Cluster Container -->
        <mxCell id="cluster-container" value="Remote Cluster" style="swimlane;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=16;fontStyle=1;startSize=40;" vertex="1" parent="1">
          <mxGeometry x="380" y="80" width="700" height="680" as="geometry"/>
        </mxCell>

        <!-- ESO Operator -->
        <mxCell id="eso-operator" value="ESO Operator&#xa;(Helm chart)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1" vertex="1" parent="cluster-container">
          <mxGeometry x="40" y="60" width="280" height="80" as="geometry"/>
        </mxCell>

        <!-- ClusterSecretStore Container -->
        <mxCell id="css-container" value="ClusterSecretStore" style="swimlane;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;startSize=35;" vertex="1" parent="cluster-container">
          <mxGeometry x="40" y="180" width="280" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="css-config" value="Provider: AWS Secrets Manager&#xa;Region: us-east-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="css-container">
          <mxGeometry x="20" y="50" width="240" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="css-irsa" value="Authentication:&#xa;IRSA (JWT ServiceAccount)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1" vertex="1" parent="css-container">
          <mxGeometry x="20" y="115" width="240" height="50" as="geometry"/>
        </mxCell>

        <!-- ExternalSecret Container -->
        <mxCell id="es-container" value="ExternalSecret" style="swimlane;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=1;startSize=35;" vertex="1" parent="cluster-container">
          <mxGeometry x="40" y="400" width="280" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="es-config" value="Fetches from:&#xa;datadog-api-keys-integration&#xa;Property: my-project-dev" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;" vertex="1" parent="es-container">
          <mxGeometry x="20" y="50" width="240" height="70" as="geometry"/>
        </mxCell>

        <!-- Kubernetes Secret -->
        <mxCell id="k8s-secret" value="Kubernetes Secret&#xa;&#xa;Name: datadog-apikey&#xa;Namespace: datadog&#xa;Key: api-key" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#f8cecc;strokeColor=#b85450;size=20;fontSize=12;fontStyle=1" vertex="1" parent="cluster-container">
          <mxGeometry x="400" y="420" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- Datadog Namespace Label -->
        <mxCell id="dd-namespace" value="datadog namespace" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;dashed=1;dashPattern=8 8;" vertex="1" parent="cluster-container">
          <mxGeometry x="400" y="380" width="240" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrows -->

        <!-- ESO manages ClusterSecretStore -->
        <mxCell id="arrow1" value="manages" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" parent="cluster-container" source="eso-operator" target="css-container">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ClusterSecretStore to ExternalSecret -->
        <mxCell id="arrow2" value="referenced by" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;" edge="1" parent="cluster-container" source="css-container" target="es-container">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ExternalSecret creates Secret -->
        <mxCell id="arrow3" value="creates" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;strokeWidth=2;fillColor=#f8cecc;strokeColor=#b85450;" edge="1" parent="cluster-container" source="es-container" target="k8s-secret">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ClusterSecretStore to AWS (IRSA auth) -->
        <mxCell id="arrow-irsa" value="Authenticates via IRSA&#xa;(IAM Role for ServiceAccount)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;strokeWidth=2;dashed=1;dashPattern=8 8;fillColor=#fff2cc;strokeColor=#d6b656;" edge="1" parent="1" source="css-irsa" target="aws-sm">
          <mxGeometry x="-0.2" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- ExternalSecret fetches from AWS -->
        <mxCell id="arrow-fetch" value="Fetches secret value" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;entryPerimeter=0;strokeWidth=3;fillColor=#FF9900;strokeColor=#FF9900;" edge="1" parent="1" source="es-config" target="aws-sm">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="340" y="545"/>
              <mxPoint x="340" y="390"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend-container" value="Component Flow" style="swimlane;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;fontColor=#333333;startSize=30;" vertex="1" parent="1">
          <mxGeometry x="380" y="780" width="700" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="legend-text" value="1. ESO Operator installed via Helm chart&#xa;2. ClusterSecretStore configured with AWS provider + IRSA authentication&#xa;3. ExternalSecret references ClusterSecretStore and fetches from AWS Secrets Manager&#xa;4. ExternalSecret creates Kubernetes Secret in datadog namespace" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="legend-container">
          <mxGeometry x="10" y="35" width="680" height="60" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
