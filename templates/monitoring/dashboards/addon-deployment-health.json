{
  "title": "ArgoCD Cluster Addons Addon Deployment Health",
  "description": "Per-addon debugging view: select a cluster and addon namespace to see pods, resources, events, and logs",
  "layout_type": "ordered",
  "template_variables": [
    {
      "name": "cluster_name",
      "prefix": "kube_cluster_name",
      "available_values": [],
      "default": "*"
    },
    {
      "name": "namespace",
      "prefix": "kube_namespace",
      "available_values": [],
      "default": "*"
    }
  ],
  "widgets": [
    {
      "definition": {
        "title": "Pod Status",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "Running",
              "type": "query_value",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "q1",
                      "data_source": "metrics",
                      "query": "sum:kubernetes_state.pod.status_phase{$cluster_name,$namespace,pod_phase:running}",
                      "aggregator": "last"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "default_zero(q1)",
                      "conditional_formats": [
                        {
                          "comparator": ">",
                          "value": 0,
                          "palette": "white_on_green"
                        }
                      ]
                    }
                  ],
                  "conditional_formats": [
                    {
                      "comparator": ">",
                      "value": 0,
                      "palette": "white_on_green"
                    }
                  ]
                }
              ],
              "autoscale": true,
              "precision": 0
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 2,
              "height": 2
            }
          },
          {
            "definition": {
              "title": "Pending",
              "type": "query_value",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "q1",
                      "data_source": "metrics",
                      "query": "sum:kubernetes_state.pod.status_phase{$cluster_name,$namespace,pod_phase:pending}",
                      "aggregator": "last"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "default_zero(q1)",
                      "conditional_formats": [
                        {
                          "comparator": "=",
                          "value": 0,
                          "palette": "white_on_green"
                        },
                        {
                          "comparator": ">",
                          "value": 0,
                          "palette": "white_on_yellow"
                        }
                      ]
                    }
                  ],
                  "conditional_formats": [
                    {
                      "comparator": "=",
                      "value": 0,
                      "palette": "white_on_green"
                    },
                    {
                      "comparator": ">",
                      "value": 0,
                      "palette": "white_on_yellow"
                    }
                  ]
                }
              ],
              "autoscale": true,
              "precision": 0
            },
            "layout": {
              "x": 2,
              "y": 0,
              "width": 2,
              "height": 2
            }
          },
          {
            "definition": {
              "title": "Failed",
              "type": "query_value",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "q1",
                      "data_source": "metrics",
                      "query": "sum:kubernetes_state.pod.status_phase{$cluster_name,$namespace,pod_phase:failed}",
                      "aggregator": "last"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "default_zero(q1)",
                      "conditional_formats": [
                        {
                          "comparator": "=",
                          "value": 0,
                          "palette": "white_on_green"
                        },
                        {
                          "comparator": ">",
                          "value": 0,
                          "palette": "white_on_red"
                        }
                      ]
                    }
                  ],
                  "conditional_formats": [
                    {
                      "comparator": "=",
                      "value": 0,
                      "palette": "white_on_green"
                    },
                    {
                      "comparator": ">",
                      "value": 0,
                      "palette": "white_on_red"
                    }
                  ]
                }
              ],
              "autoscale": true,
              "precision": 0
            },
            "layout": {
              "x": 4,
              "y": 0,
              "width": 2,
              "height": 2
            }
          },
          {
            "definition": {
              "title": "CrashLoop",
              "type": "query_value",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "q1",
                      "data_source": "metrics",
                      "query": "sum:kubernetes_state.container.waiting.reason{$cluster_name,$namespace,reason:crashloopbackoff}",
                      "aggregator": "last"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "default_zero(q1)",
                      "conditional_formats": [
                        {
                          "comparator": "=",
                          "value": 0,
                          "palette": "white_on_green"
                        },
                        {
                          "comparator": ">",
                          "value": 0,
                          "palette": "white_on_red"
                        }
                      ]
                    }
                  ],
                  "conditional_formats": [
                    {
                      "comparator": "=",
                      "value": 0,
                      "palette": "white_on_green"
                    },
                    {
                      "comparator": ">",
                      "value": 0,
                      "palette": "white_on_red"
                    }
                  ]
                }
              ],
              "autoscale": true,
              "precision": 0
            },
            "layout": {
              "x": 6,
              "y": 0,
              "width": 2,
              "height": 2
            }
          },
          {
            "definition": {
              "title": "OOMKilled",
              "type": "query_value",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "q1",
                      "data_source": "metrics",
                      "query": "sum:kubernetes_state.container.status_report.count.terminated{$cluster_name,$namespace,reason:oomkilled}",
                      "aggregator": "last"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "default_zero(q1)",
                      "conditional_formats": [
                        {
                          "comparator": "=",
                          "value": 0,
                          "palette": "white_on_green"
                        },
                        {
                          "comparator": ">",
                          "value": 0,
                          "palette": "white_on_red"
                        }
                      ]
                    }
                  ],
                  "conditional_formats": [
                    {
                      "comparator": "=",
                      "value": 0,
                      "palette": "white_on_green"
                    },
                    {
                      "comparator": ">",
                      "value": 0,
                      "palette": "white_on_red"
                    }
                  ]
                }
              ],
              "autoscale": true,
              "precision": 0
            },
            "layout": {
              "x": 8,
              "y": 0,
              "width": 4,
              "height": 2
            }
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 12,
        "height": 4
      }
    },
    {
      "definition": {
        "title": "Pods",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "Pod Details",
              "type": "query_table",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "cpu",
                      "query": "avg:kubernetes.cpu.usage.total{$cluster_name,$namespace} by {pod_name}",
                      "aggregator": "last"
                    },
                    {
                      "data_source": "metrics",
                      "name": "mem",
                      "query": "avg:kubernetes.memory.usage{$cluster_name,$namespace} by {pod_name}",
                      "aggregator": "last"
                    },
                    {
                      "data_source": "metrics",
                      "name": "restarts",
                      "query": "max:kubernetes_state.container.restarts{$cluster_name,$namespace} by {pod_name}",
                      "aggregator": "last"
                    }
                  ],
                  "formulas": [
                    {
                      "alias": "CPU (m)",
                      "cell_display_mode": "bar",
                      "formula": "cpu / 1000000"
                    },
                    {
                      "alias": "Memory (MB)",
                      "cell_display_mode": "bar",
                      "formula": "mem / 1048576"
                    },
                    {
                      "alias": "Restarts",
                      "formula": "restarts",
                      "conditional_formats": [
                        {
                          "comparator": "=",
                          "value": 0,
                          "palette": "white_on_green"
                        },
                        {
                          "comparator": ">",
                          "value": 0,
                          "palette": "white_on_red"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 12,
              "height": 5
            }
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 4,
        "width": 12,
        "height": 7
      }
    },
    {
      "definition": {
        "title": "Resource Usage",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "CPU \u2014 Usage vs Requests vs Limits",
              "show_legend": true,
              "legend_layout": "auto",
              "type": "timeseries",
              "requests": [
                {
                  "response_format": "timeseries",
                  "queries": [
                    {
                      "name": "usage",
                      "data_source": "metrics",
                      "query": "sum:kubernetes.cpu.usage.total{$cluster_name,$namespace}"
                    },
                    {
                      "name": "reqs",
                      "data_source": "metrics",
                      "query": "sum:kubernetes.cpu.requests{$cluster_name,$namespace}"
                    },
                    {
                      "name": "lims",
                      "data_source": "metrics",
                      "query": "sum:kubernetes.cpu.limits{$cluster_name,$namespace}"
                    }
                  ],
                  "formulas": [
                    {
                      "alias": "Usage (m)",
                      "formula": "usage / 1000000"
                    },
                    {
                      "alias": "Requests (m)",
                      "formula": "reqs * 1000"
                    },
                    {
                      "alias": "Limits (m)",
                      "formula": "lims * 1000"
                    }
                  ],
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "display_type": "line"
                }
              ],
              "yaxis": {
                "include_zero": true,
                "min": "0"
              }
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 6,
              "height": 3
            }
          },
          {
            "definition": {
              "title": "Memory \u2014 Usage vs Requests vs Limits",
              "show_legend": true,
              "legend_layout": "auto",
              "type": "timeseries",
              "requests": [
                {
                  "response_format": "timeseries",
                  "queries": [
                    {
                      "name": "usage",
                      "data_source": "metrics",
                      "query": "sum:kubernetes.memory.usage{$cluster_name,$namespace}"
                    },
                    {
                      "name": "reqs",
                      "data_source": "metrics",
                      "query": "sum:kubernetes.memory.requests{$cluster_name,$namespace}"
                    },
                    {
                      "name": "lims",
                      "data_source": "metrics",
                      "query": "sum:kubernetes.memory.limits{$cluster_name,$namespace}"
                    }
                  ],
                  "formulas": [
                    {
                      "alias": "Usage (MB)",
                      "formula": "usage / 1048576"
                    },
                    {
                      "alias": "Requests (MB)",
                      "formula": "reqs / 1048576"
                    },
                    {
                      "alias": "Limits (MB)",
                      "formula": "lims / 1048576"
                    }
                  ],
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "display_type": "line"
                }
              ],
              "yaxis": {
                "include_zero": true,
                "min": "0"
              }
            },
            "layout": {
              "x": 6,
              "y": 0,
              "width": 6,
              "height": 3
            }
          },
          {
            "definition": {
              "title": "Pod Restarts Over Time",
              "show_legend": false,
              "type": "timeseries",
              "time": {
                "live_span": "1d"
              },
              "requests": [
                {
                  "response_format": "timeseries",
                  "queries": [
                    {
                      "name": "q1",
                      "data_source": "metrics",
                      "query": "sum:kubernetes_state.container.restarts{$cluster_name,$namespace} by {pod_name}"
                    }
                  ],
                  "formulas": [
                    {
                      "alias": "Restarts",
                      "formula": "q1"
                    }
                  ],
                  "style": {
                    "palette": "warm",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "display_type": "bars"
                }
              ],
              "yaxis": {
                "include_zero": true,
                "min": "0"
              }
            },
            "layout": {
              "x": 0,
              "y": 3,
              "width": 12,
              "height": 3
            }
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 11,
        "width": 12,
        "height": 8
      }
    },
    {
      "definition": {
        "title": "Kubernetes Events",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "Events",
              "requests": [
                {
                  "response_format": "event_list",
                  "query": {
                    "data_source": "event_stream",
                    "query_string": "source:kubernetes $cluster_name $namespace",
                    "event_size": "s"
                  },
                  "columns": []
                }
              ],
              "type": "list_stream",
              "time": {
                "live_span": "4h"
              }
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 12,
              "height": 5
            }
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 19,
        "width": 12,
        "height": 7
      }
    },
    {
      "definition": {
        "title": "Logs",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "All Logs",
              "type": "log_stream",
              "query": "$cluster_name $namespace -\"use of closed network connection\" -\"connection refused\" -\"connection reset by peer\"",
              "indexes": [
                "*"
              ],
              "columns": [
                "core_service",
                "status"
              ],
              "show_date_column": true,
              "show_message_column": true,
              "message_display": "expanded-md",
              "sort": {
                "column": "time",
                "order": "desc"
              },
              "time": {
                "live_span": "4h"
              }
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 12,
              "height": 6
            }
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 26,
        "width": 12,
        "height": 8
      }
    }
  ]
}
