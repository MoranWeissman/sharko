{
  "title": "ArgoCD Cluster Addons Application Operations",
  "description": "Application sync status, health, and ArgoCD control plane overview",
  "layout_type": "ordered",
  "template_variables": [
    {
      "name": "cluster_name",
      "prefix": "kube_cluster_name",
      "available_values": ["devops-argocd-addons-dev-eks"],
      "default": "devops-argocd-addons-dev-eks"
    },
    {
      "name": "addon",
      "prefix": "argocd_project",
      "available_values": [],
      "default": "*"
    }
  ],
  "widgets": [
    {
      "id": 1000000001,
      "definition": {
        "title": "ArgoCD Components Health",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {"id":1000000002,"definition":{"title":"App Controller","type":"query_value","requests":[{"response_format":"scalar","queries":[{"name":"q1","data_source":"metrics","query":"min:kubernetes_state.statefulset.replicas_ready{$cluster_name,kube_namespace:argocd,kube_stateful_set:*application-cont*}","aggregator":"last"}],"formulas":[{"formula":"q1","conditional_formats":[{"comparator":">=","value":1,"palette":"white_on_green"},{"comparator":"<","value":1,"palette":"white_on_red"}]}],"conditional_formats":[{"comparator":">=","value":1,"palette":"white_on_green"},{"comparator":"<","value":1,"palette":"white_on_red"}]}],"autoscale":false,"precision":0,"timeseries_background":{"type":"area"}},"layout":{"x":0,"y":0,"width":2,"height":2}},
          {"id":1000000003,"definition":{"title":"AppSet Controller","type":"query_value","requests":[{"response_format":"scalar","queries":[{"name":"q1","data_source":"metrics","query":"min:kubernetes_state.deployment.replicas_available{$cluster_name,kube_namespace:argocd,kube_deployment:*applicationset*}","aggregator":"last"}],"formulas":[{"formula":"q1","conditional_formats":[{"comparator":">=","value":1,"palette":"white_on_green"},{"comparator":"<","value":1,"palette":"white_on_red"}]}],"conditional_formats":[{"comparator":">=","value":1,"palette":"white_on_green"},{"comparator":"<","value":1,"palette":"white_on_red"}]}],"autoscale":false,"precision":0,"timeseries_background":{"type":"area"}},"layout":{"x":2,"y":0,"width":2,"height":2}},
          {"id":1000000004,"definition":{"title":"API Server","type":"query_value","requests":[{"response_format":"scalar","queries":[{"name":"q1","data_source":"metrics","query":"min:kubernetes_state.deployment.replicas_available{$cluster_name,kube_namespace:argocd,kube_deployment:*server}","aggregator":"last"}],"formulas":[{"formula":"q1","conditional_formats":[{"comparator":">=","value":1,"palette":"white_on_green"},{"comparator":"<","value":1,"palette":"white_on_red"}]}],"conditional_formats":[{"comparator":">=","value":1,"palette":"white_on_green"},{"comparator":"<","value":1,"palette":"white_on_red"}]}],"autoscale":false,"precision":0,"timeseries_background":{"type":"area"}},"layout":{"x":4,"y":0,"width":2,"height":2}},
          {"id":1000000005,"definition":{"title":"Repo Server","type":"query_value","requests":[{"response_format":"scalar","queries":[{"name":"q1","data_source":"metrics","query":"min:kubernetes_state.deployment.replicas_available{$cluster_name,kube_namespace:argocd,kube_deployment:*repo-server*}","aggregator":"last"}],"formulas":[{"formula":"q1","conditional_formats":[{"comparator":">=","value":1,"palette":"white_on_green"},{"comparator":"<","value":1,"palette":"white_on_red"}]}],"conditional_formats":[{"comparator":">=","value":1,"palette":"white_on_green"},{"comparator":"<","value":1,"palette":"white_on_red"}]}],"autoscale":false,"precision":0,"timeseries_background":{"type":"area"}},"layout":{"x":6,"y":0,"width":2,"height":2}},
          {"id":1000000006,"definition":{"title":"Work Queue Depth","type":"query_value","requests":[{"response_format":"scalar","queries":[{"name":"q1","data_source":"metrics","query":"sum:argocd.app_controller.workqueue.depth{*}","aggregator":"last"}],"formulas":[{"formula":"q1","conditional_formats":[{"comparator":"<=","value":10,"palette":"white_on_green"},{"comparator":"<=","value":50,"palette":"white_on_yellow"},{"comparator":">","value":50,"palette":"white_on_red"}]}],"conditional_formats":[{"comparator":"<=","value":10,"palette":"white_on_green"},{"comparator":"<=","value":50,"palette":"white_on_yellow"},{"comparator":">","value":50,"palette":"white_on_red"}]}],"autoscale":true,"precision":0,"timeseries_background":{"type":"area"}},"layout":{"x":8,"y":0,"width":2,"height":2}},
          {"id":1000000007,"definition":{"title":"Reconciliation Avg","type":"query_value","requests":[{"response_format":"scalar","queries":[{"name":"s","data_source":"metrics","query":"avg:argocd.app_controller.app.reconcile.sum{*}","aggregator":"last"},{"name":"c","data_source":"metrics","query":"avg:argocd.app_controller.app.reconcile.count{*}","aggregator":"last"}],"formulas":[{"formula":"s / c","number_format":{"unit":{"type":"canonical_unit","unit_name":"second"}},"conditional_formats":[{"comparator":"<","value":5,"palette":"white_on_green"},{"comparator":"<","value":10,"palette":"white_on_yellow"},{"comparator":">=","value":10,"palette":"white_on_red"}]}],"conditional_formats":[{"comparator":"<","value":5,"palette":"white_on_green"},{"comparator":"<","value":10,"palette":"white_on_yellow"},{"comparator":">=","value":10,"palette":"white_on_red"}]}],"autoscale":true,"precision":1,"timeseries_background":{"type":"area"}},"layout":{"x":10,"y":0,"width":2,"height":2}}
        ]
      },
      "layout": {"x":0,"y":0,"width":12,"height":4}
    },
    {
      "id": 1000000010,
      "definition": {
        "title": "Application Status",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {"id":1000000011,"definition":{"title":"Total Apps","type":"query_value","requests":[{"response_format":"scalar","queries":[{"name":"q1","data_source":"metrics","query":"count:argocd.app_controller.app.info{*}","aggregator":"last"}],"formulas":[{"formula":"q1"}]}],"autoscale":true,"precision":0,"timeseries_background":{"type":"area"}},"layout":{"x":0,"y":0,"width":2,"height":2}},
          {"id":1000000012,"definition":{"title":"Healthy","type":"query_value","requests":[{"response_format":"scalar","queries":[{"name":"q1","data_source":"metrics","query":"count:argocd.app_controller.app.info{health_status:healthy}","aggregator":"last"}],"formulas":[{"formula":"q1","conditional_formats":[{"comparator":">","value":0,"palette":"white_on_green"}]}],"conditional_formats":[{"comparator":">","value":0,"palette":"white_on_green"}]}],"autoscale":true,"precision":0,"timeseries_background":{"type":"area"}},"layout":{"x":2,"y":0,"width":2,"height":2}},
          {"id":1000000013,"definition":{"title":"Degraded","type":"query_value","requests":[{"response_format":"scalar","queries":[{"name":"q1","data_source":"metrics","query":"count:argocd.app_controller.app.info{health_status:degraded}","aggregator":"last"}],"formulas":[{"formula":"default_zero(q1)","conditional_formats":[{"comparator":"=","value":0,"palette":"white_on_green"},{"comparator":">","value":0,"palette":"white_on_red"}]}],"conditional_formats":[{"comparator":"=","value":0,"palette":"white_on_green"},{"comparator":">","value":0,"palette":"white_on_red"}]}],"autoscale":true,"precision":0,"timeseries_background":{"type":"area"}},"layout":{"x":4,"y":0,"width":2,"height":2}},
          {"id":1000000014,"definition":{"title":"Progressing","type":"query_value","requests":[{"response_format":"scalar","queries":[{"name":"q1","data_source":"metrics","query":"count:argocd.app_controller.app.info{health_status:progressing}","aggregator":"last"}],"formulas":[{"formula":"default_zero(q1)","conditional_formats":[{"comparator":"=","value":0,"palette":"white_on_green"},{"comparator":">","value":0,"palette":"white_on_yellow"}]}],"conditional_formats":[{"comparator":"=","value":0,"palette":"white_on_green"},{"comparator":">","value":0,"palette":"white_on_yellow"}]}],"autoscale":true,"precision":0,"timeseries_background":{"type":"area"}},"layout":{"x":6,"y":0,"width":2,"height":2}},
          {"id":1000000015,"definition":{"title":"Failed Syncs (1h)","type":"query_value","requests":[{"response_format":"scalar","queries":[{"name":"q1","data_source":"metrics","query":"sum:argocd.app_controller.app.sync.count{phase:error}.as_count()","aggregator":"sum"}],"formulas":[{"formula":"default_zero(q1)","conditional_formats":[{"comparator":"=","value":0,"palette":"white_on_green"},{"comparator":">","value":0,"palette":"white_on_red"}]}],"conditional_formats":[{"comparator":"=","value":0,"palette":"white_on_green"},{"comparator":">","value":0,"palette":"white_on_red"}]}],"autoscale":true,"precision":0,"timeseries_background":{"type":"area"}},"layout":{"x":8,"y":0,"width":2,"height":2}},
          {"id":1000000016,"definition":{"title":"Succeeded Syncs (1h)","type":"query_value","requests":[{"response_format":"scalar","queries":[{"name":"q1","data_source":"metrics","query":"sum:argocd.app_controller.app.sync.count{phase:succeeded}.as_count()","aggregator":"sum"}],"formulas":[{"formula":"default_zero(q1)","conditional_formats":[{"comparator":">","value":0,"palette":"white_on_green"}]}],"conditional_formats":[{"comparator":">","value":0,"palette":"white_on_green"}]}],"autoscale":true,"precision":0,"timeseries_background":{"type":"area"}},"layout":{"x":10,"y":0,"width":2,"height":2}}
        ]
      },
      "layout": {"x":0,"y":4,"width":12,"height":4}
    },
    {
      "id": 1000000020,
      "definition": {
        "title": "Connected Clusters",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 1000000021,
            "definition": {
              "title": "Cluster Connection Status",
              "type": "query_table",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "conn",
                      "query": "min:argocd.app_controller.argocd_cluster_connection_status{*} by {server}",
                      "aggregator": "last"
                    }
                  ],
                  "formulas": [
                    {
                      "alias": "Connected",
                      "formula": "conn",
                      "conditional_formats": [
                        {"comparator":">=","value":1,"palette":"white_on_green"},
                        {"comparator":"<","value":1,"palette":"white_on_red"}
                      ]
                    }
                  ]
                }
              ]
            },
            "layout": {"x":0,"y":0,"width":12,"height":3}
          }
        ]
      },
      "layout": {"x":0,"y":8,"width":12,"height":5}
    },
    {
      "id": 1000000030,
      "definition": {
        "title": "Addon Health Overview",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 1000000031,
            "definition": {
              "title": "Addon Health (one box per addon type — green = all healthy, red = any degraded)",
              "title_size": "16",
              "type": "treemap",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "healthy",
                      "query": "count:argocd.app_controller.app.info{health_status:healthy,!argocd_project:cluster-addons,!argocd_project:karpenter-nodepools,!argocd_project:external-secrets-operator,$addon} by {argocd_project}",
                      "aggregator": "last"
                    },
                    {
                      "data_source": "metrics",
                      "name": "degraded",
                      "query": "count:argocd.app_controller.app.info{health_status:degraded,!argocd_project:cluster-addons,!argocd_project:karpenter-nodepools,!argocd_project:external-secrets-operator,$addon} by {argocd_project}",
                      "aggregator": "last"
                    }
                  ],
                  "formulas": [
                    {
                      "alias": "Healthy",
                      "formula": "healthy"
                    },
                    {
                      "alias": "Degraded",
                      "formula": "default_zero(degraded)"
                    }
                  ],
                  "style": {
                    "palette": "green_to_orange"
                  }
                }
              ]
            },
            "layout": {"x":0,"y":0,"width":12,"height":4}
          },
          {
            "id": 1000000032,
            "definition": {
              "title": "Addon Summary",
              "type": "query_table",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "total",
                      "query": "count:argocd.app_controller.app.info{!argocd_project:cluster-addons,!argocd_project:karpenter-nodepools,!argocd_project:external-secrets-operator,$addon} by {argocd_project}",
                      "aggregator": "last"
                    },
                    {
                      "data_source": "metrics",
                      "name": "healthy",
                      "query": "count:argocd.app_controller.app.info{health_status:healthy,!argocd_project:cluster-addons,!argocd_project:karpenter-nodepools,!argocd_project:external-secrets-operator,$addon} by {argocd_project}",
                      "aggregator": "last"
                    },
                    {
                      "data_source": "metrics",
                      "name": "degraded",
                      "query": "count:argocd.app_controller.app.info{health_status:degraded,!argocd_project:cluster-addons,!argocd_project:karpenter-nodepools,!argocd_project:external-secrets-operator,$addon} by {argocd_project}",
                      "aggregator": "last"
                    },
                    {
                      "data_source": "metrics",
                      "name": "progressing",
                      "query": "count:argocd.app_controller.app.info{health_status:progressing,!argocd_project:cluster-addons,!argocd_project:karpenter-nodepools,!argocd_project:external-secrets-operator,$addon} by {argocd_project}",
                      "aggregator": "last"
                    }
                  ],
                  "formulas": [
                    {"alias": "Deployments", "formula": "total"},
                    {
                      "alias": "Healthy",
                      "formula": "default_zero(healthy)",
                      "conditional_formats": [{"comparator":">","value":0,"palette":"white_on_green"}]
                    },
                    {
                      "alias": "Degraded",
                      "formula": "default_zero(degraded)",
                      "conditional_formats": [
                        {"comparator":"=","value":0,"palette":"white_on_green"},
                        {"comparator":">","value":0,"palette":"white_on_red"}
                      ]
                    },
                    {
                      "alias": "Progressing",
                      "formula": "default_zero(progressing)",
                      "conditional_formats": [
                        {"comparator":"=","value":0,"palette":"white_on_green"},
                        {"comparator":">","value":0,"palette":"white_on_yellow"}
                      ]
                    }
                  ]
                }
              ]
            },
            "layout": {"x":0,"y":4,"width":12,"height":4}
          }
        ]
      },
      "layout": {"x":0,"y":13,"width":12,"height":10}
    },
    {
      "id": 1000000040,
      "definition": {
        "title": "Trends",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {"id":1000000041,"definition":{"title":"Sync Operations — actual deploys to clusters (empty = no changes pushed)","show_legend":true,"legend_layout":"auto","type":"timeseries","requests":[{"response_format":"timeseries","queries":[{"name":"succeeded","data_source":"metrics","query":"sum:argocd.app_controller.app.sync.count{phase:succeeded}.as_count()"},{"name":"failed","data_source":"metrics","query":"sum:argocd.app_controller.app.sync.count{phase:error}.as_count()"}],"formulas":[{"alias":"Succeeded","formula":"succeeded","style":{"palette":"green"}},{"alias":"Failed","formula":"failed","style":{"palette":"red"}}],"style":{"palette":"dog_classic","line_type":"solid","line_width":"normal"},"display_type":"bars"}],"yaxis":{"include_zero":true,"min":"0"}},"layout":{"x":0,"y":0,"width":6,"height":3}},
          {"id":1000000042,"definition":{"title":"Sync Failure Rate — % of syncs that failed (empty = no syncs happened)","show_legend":false,"type":"timeseries","requests":[{"response_format":"timeseries","queries":[{"name":"failed","data_source":"metrics","query":"sum:argocd.app_controller.app.sync.count{phase:error}.as_count()"},{"name":"total","data_source":"metrics","query":"sum:argocd.app_controller.app.sync.count{*}.as_count()"}],"formulas":[{"alias":"Failure Rate %","formula":"(failed / total) * 100"}],"style":{"palette":"warm","line_type":"solid","line_width":"normal"},"display_type":"line"}],"yaxis":{"include_zero":true,"min":"0","max":"100"},"markers":[{"label":"Warning","value":"y = 5","display_type":"warning dashed"}]},"layout":{"x":6,"y":0,"width":6,"height":3}},
          {"id":1000000043,"definition":{"title":"Reconciliation Duration — how long ArgoCD takes to check app state (seconds)","show_legend":false,"type":"timeseries","requests":[{"response_format":"timeseries","queries":[{"name":"s","data_source":"metrics","query":"sum:argocd.app_controller.app.reconcile.sum{*}.as_rate()"},{"name":"c","data_source":"metrics","query":"sum:argocd.app_controller.app.reconcile.count{*}.as_rate()"}],"formulas":[{"alias":"Avg Duration","formula":"s / c"}],"style":{"palette":"purple","line_type":"solid","line_width":"normal"},"display_type":"line"}],"yaxis":{"include_zero":true,"min":"0"},"markers":[{"label":"Warning","value":"y = 10","display_type":"warning dashed"},{"label":"Critical","value":"y = 30","display_type":"error dashed"}]},"layout":{"x":0,"y":3,"width":6,"height":3}},
          {"id":1000000044,"definition":{"title":"Work Queue Depth — apps waiting to be processed (0 = healthy)","show_legend":false,"type":"timeseries","requests":[{"response_format":"timeseries","queries":[{"name":"q1","data_source":"metrics","query":"avg:argocd.app_controller.workqueue.depth{*}"}],"formulas":[{"alias":"Queue Depth","formula":"q1"}],"style":{"palette":"orange","line_type":"solid","line_width":"normal"},"display_type":"line"}],"yaxis":{"include_zero":true,"min":"0"},"markers":[{"label":"Warning","value":"y = 50","display_type":"warning dashed"}]},"layout":{"x":6,"y":3,"width":6,"height":3}},
          {"id":1000000045,"definition":{"title":"Failure Categories — requires log pipeline setup (see monitoring/log-pipelines/)","type":"toplist","requests":[{"response_format":"scalar","queries":[{"data_source":"logs","name":"q1","search":{"query":"source:argocd status:error"},"indexes":["*"],"group_by":[{"facet":"@failure_category","sort":{"aggregation":"count","order":"desc"},"limit":10}],"compute":{"aggregation":"count"}}],"formulas":[{"formula":"q1"}]}],"time":{"live_span":"1d"}},"layout":{"x":0,"y":6,"width":6,"height":3}},
          {"id":1000000046,"definition":{"title":"Error Logs by ArgoCD Component","type":"toplist","requests":[{"response_format":"scalar","queries":[{"data_source":"logs","name":"q1","search":{"query":"source:argocd status:error"},"indexes":["*"],"group_by":[{"facet":"kube_container_name","sort":{"aggregation":"count","order":"desc"},"limit":10}],"compute":{"aggregation":"count"}}],"formulas":[{"formula":"q1"}]}],"time":{"live_span":"1d"}},"layout":{"x":6,"y":6,"width":6,"height":3}}
        ]
      },
      "layout": {"x":0,"y":29,"width":12,"height":11}
    }
  ],
  "notify_list": []
}
