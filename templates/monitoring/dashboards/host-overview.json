    {
      "id": 6177546390743471,
      "definition": {
        "title": "Node CPU Utilization",
        "show_legend": false,
        "type": "timeseries",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "name": "cpu",
                "data_source": "metrics",
                "query": "avg:system.cpu.user{$cluster_name} by {host}"
              }
            ],
            "formulas": [
              {
                "alias": "CPU %",
                "formula": "cpu"
              }
            ],
            "style": {
              "palette": "dog_classic",
              "line_type": "solid",
              "line_width": "normal"
            },
            "display_type": "line"
          }
        ],
        "yaxis": {
          "include_zero": true,
          "min": "0",
          "max": "100"
