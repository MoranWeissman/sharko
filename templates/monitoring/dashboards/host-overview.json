    {
      "id": 3391511981297644,
      "definition": {
        "title": "Core Components",
        "type": "query_table",
        "requests": [
          {
            "response_format": "scalar",
            "queries": [
              {
                "data_source": "metrics",
                "name": "q1",
                "query": "max:kubernetes.cpu.usage.total{$cluster_name AND kube_namespace IN (argocd,external-secrets)} by {kube_app_name}",
                "aggregator": "last"
              },
              {
                "data_source": "metrics",
                "name": "q2",
                "query": "max:kubernetes.memory.usage{$cluster_name AND kube_namespace IN (argocd,external-secrets)} by {kube_app_name}",
                "aggregator": "last"
              },
              {
                "data_source": "metrics",
                "name": "q3",
                "query": "max:kubernetes_state.container.restarts{$cluster_name AND kube_namespace IN (argocd,external-secrets)} by {kube_app_name}",
                "aggregator": "last"
              }
            ],
            "formulas": [
              {
                "alias": "CPU (m)",
                "cell_display_mode": "bar",
                "formula": "q1 / 1000000"
              },
              {
                "alias": "Memory",
                "cell_display_mode": "bar",
                "formula": "q2"
              },
              {
                "alias": "Restarts",
                "formula": "q3",
                "conditional_formats": [
                  {
                    "comparator": "=",
                    "value": 0,
                    "palette": "white_on_green"
                  },
                  {
                    "comparator": ">",
                    "value": 0,
                    "palette": "white_on_red"
                  }
                ]
              }
            ]
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 5,
        "width": 12,
        "height": 4
      }
    },
