    {
      "id": 6264493205395697,
      "definition": {
        "title": "CPU - Usage vs Requests vs Limits (cluster total)",
        "show_legend": true,
        "legend_layout": "auto",
        "type": "timeseries",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "name": "usage",
                "data_source": "metrics",
                "query": "sum:kubernetes.cpu.usage.total{$cluster_name AND kube_namespace IN (argocd,external-secrets,kube-system)}"
              },
              {
                "name": "reqs",
                "data_source": "metrics",
                "query": "sum:kubernetes.cpu.requests{$cluster_name AND kube_namespace IN (argocd,external-secrets,kube-system)}"
              },
              {
                "name": "lims",
                "data_source": "metrics",
                "query": "sum:kubernetes.cpu.limits{$cluster_name AND kube_namespace IN (argocd,external-secrets,kube-system)}"
              }
            ],
            "formulas": [
              {
                "alias": "Usage (m)",
                "formula": "usage / 1000000"
              },
              {
                "alias": "Requests (m)",
                "formula": "reqs * 1000"
              },
              {
                "alias": "Limits (m)",
                "formula": "lims * 1000"
              }
            ],
            "style": {
              "palette": "dog_classic",
              "line_type": "solid",
              "line_width": "normal"
            },
            "display_type": "line"
          }
        ],
        "yaxis": {
