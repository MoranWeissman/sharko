{
  "title": "ArgoCD Cluster Addons Host Cluster",
  "description": "Host cluster infrastructure health monitoring for ArgoCD and ESO",
  "widgets": [
    {
      "id": 5934540039213112,
      "definition": {
        "title": "Nodes Ready",
        "type": "query_value",
        "requests": [
          {
            "response_format": "scalar",
            "queries": [
              {
                "name": "q1",
                "data_source": "metrics",
                "query": "sum:kubernetes_state.node.count{$cluster_name}",
                "aggregator": "last"
              }
            ],
            "formulas": [
              {
                "formula": "q1",
                "conditional_formats": [
                  {
                    "comparator": ">=",
                    "value": 1,
                    "palette": "white_on_green"
                  },
                  {
                    "comparator": "<",
                    "value": 1,
                    "palette": "white_on_red"
                  }
                ]
              }
            ],
            "conditional_formats": [
              {
                "comparator": "=",
                "value": 0,
                "palette": "white_on_red"
              },
              {
                "comparator": ">",
                "value": 0,
                "palette": "white_on_green"
              }
            ]
          }
        ],
        "autoscale": true,
        "precision": 0,
        "timeseries_background": {
          "type": "area"
        }
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 3,
        "height": 2
      }
    },
    {
      "id": 6873358654880615,
      "definition": {
        "title": "Avg Node CPU",
        "type": "query_value",
        "requests": [
          {
            "response_format": "scalar",
            "queries": [
              {
                "name": "q1",
                "data_source": "metrics",
                "query": "avg:system.cpu.idle{$cluster_name}",
                "aggregator": "last"
              }
            ],
            "formulas": [
              {
                "formula": "100 - q1",
                "number_format": {
                  "unit": {
                    "type": "canonical_unit",
                    "unit_name": "percent"
                  }
                },
                "conditional_formats": [
                  {
                    "comparator": "<",
                    "value": 70,
                    "palette": "white_on_green"
                  },
                  {
                    "comparator": "<",
                    "value": 85,
                    "palette": "white_on_yellow"
                  },
                  {
                    "comparator": ">=",
                    "value": 85,
                    "palette": "white_on_red"
                  }
                ]
              }
            ],
            "conditional_formats": [
              {
                "comparator": "<",
                "value": 75,
                "palette": "white_on_green"
              },
              {
                "comparator": "<",
                "value": 85,
                "palette": "white_on_yellow"
              },
              {
                "comparator": ">=",
                "value": 85,
                "palette": "white_on_red"
              }
            ]
          }
        ],
        "autoscale": true,
        "precision": 1,
        "timeseries_background": {
          "type": "area"
        }
      },
      "layout": {
        "x": 3,
        "y": 0,
        "width": 3,
        "height": 2
      }
    },
    {
      "id": 566625404263792,
      "definition": {
        "title": "Avg Node Memory",
        "type": "query_value",
        "requests": [
          {
            "response_format": "scalar",
            "queries": [
              {
                "name": "total",
                "data_source": "metrics",
                "query": "avg:system.mem.total{$cluster_name}",
                "aggregator": "last"
              },
              {
                "name": "usable",
                "data_source": "metrics",
                "query": "avg:system.mem.usable{$cluster_name}",
                "aggregator": "last"
              }
            ],
            "formulas": [
              {
                "formula": "((total - usable) / total) * 100",
                "number_format": {
                  "unit": {
                    "type": "canonical_unit",
                    "unit_name": "percent"
                  }
                },
                "conditional_formats": [
                  {
                    "comparator": "<",
                    "value": 70,
                    "palette": "white_on_green"
                  },
                  {
                    "comparator": "<",
                    "value": 85,
                    "palette": "white_on_yellow"
                  },
                  {
                    "comparator": ">=",
                    "value": 85,
                    "palette": "white_on_red"
                  }
                ]
              }
            ],
            "conditional_formats": [
              {
                "comparator": "<",
                "value": 75,
                "palette": "white_on_green"
              },
              {
                "comparator": "<",
                "value": 85,
                "palette": "white_on_yellow"
              },
              {
                "comparator": ">=",
                "value": 85,
                "palette": "white_on_red"
              }
            ]
          }
        ],
        "autoscale": true,
        "precision": 1,
        "timeseries_background": {
          "type": "area"
